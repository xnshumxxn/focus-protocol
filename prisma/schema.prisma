generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  image     String?

  projects  Project[]

  createdAt DateTime  @default(now())
}

model Project {
  id          String    @id @default(cuid())

  name        String

  color       String    @default("#6366f1")

  userId      String
  user        User      @relation(fields: [userId], references: [id])

  sessions    Session[]

  createdAt   DateTime @default(now())
}

model Session {
  id          String   @id @default(cuid())

  duration    Int

  startedAt   DateTime

  endedAt     DateTime

  projectId   String
  project     Project @relation(fields: [projectId], references: [id])

  createdAt   DateTime @default(now())
}